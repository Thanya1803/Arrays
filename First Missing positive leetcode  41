class Solution 
{
    public int firstMissingPositive(int[] nums) 
    {
        Set<Integer> set = new HashSet<>();
        int n=nums.length;
        for(int i=0;i<n;i++)
        {
            if(nums[i]>0)
            {
                set.add(nums[i]);
                
            }
        }
        int miss=1;
        while(set.contains(miss))
        {
            miss++;
        }
                return miss;

    

    }
}
